# Web client (Next.js)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_FUNCTION_URL= # e.g. https://<project-ref>.supabase.co/functions/v1/coach-orchestrator

# Edge Function (set as Supabase secrets)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# If you don't have paid API access yet, you can run in mock mode:
# COACH_LLM_MODE=mock
